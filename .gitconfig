[user]
	email = ayush
[init]
	defaultBranch = main
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between files
    light = false      # set to true if you use a light terminal theme
    line-numbers = true

[diff]
    colorMoved = default

