###############     Autostart      ##################
set $Mod Mod4
exec wl-paste --watch cliphist store
exec python ~/.config/sway/sway-contrib/inactive-windows-transparency.py
exec waybar
exec nm-applet
exec blueman-applet
exec swww-daemon
exec ~/.config/sway/scripts/battery_notify.sh
exec autotiling-rs
exec_always ~/.config/sway/scripts/waybar.sh
exec_always mako
##song notification
exec --no-startup-id ~/.config/sway/scripts/song-change.sh
## screen sharing
exec --no-startup-id dbus-update-activation-environment --systemd \
   WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway XDG_SESSION_DESKTOP=sway XDG_SESSION_TYPE=wayland
exec --no-startup-id systemctl --user start pipewire wireplumber xdg-desktop-portal xdg-desktop-portal-wlr
