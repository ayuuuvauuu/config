function fish_prompt --description "Write out the prompt"
    if set -q _tide_transient
        set -e _tide_transient
        set_color yellow --bold
        echo -n "\$ "
        set_color normal
        return
    end

    set -l pwd_info (prompt_pwd)
    set -l git_branch (command git symbolic-ref --short HEAD 2>/dev/null; or command git rev-parse --short HEAD 2>/dev/null)

    set_color white --bold
    echo -n "$pwd_info"
    set_color normal

    if test -n "$git_branch"
        set_color yellow --bold
        echo -n " $git_branch"
        if not command git diff --quiet 2>/dev/null
            set_color red
            echo -n "*"
        else if not command git diff --cached --quiet 2>/dev/null
            set_color green
            echo -n "+"
        end
        set_color normal
    end

    echo -n " "
    set_color green --bold
    switch $fish_bind_mode
        case default
            set_color red --bold
            echo -n "[N]"
        case visual
            set_color magenta --bold
            echo -n "[V]"
        case '*'
            echo -n "[I]"
    end
    set_color normal
    echo
    set_color yellow --bold
    echo -n "\$ "
    set_color normal
end
