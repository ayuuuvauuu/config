#!/usr/bin/env bash
set -euo pipefail

PID_FILE="${PDANET_PROXY_PID_FILE:-/tmp/pdanet-proxy.pid}"

die() { echo "ERROR: $*" >&2; exit 1; }
info() { echo "$*"; }
check_root() { [[ $EUID -ne 0 ]] && die "root required (sudo)."; }

CHAIN="PDANET"

wait_for_exit() {
    local pid=$1
    local i
    for i in {1..100}; do
        kill -0 "$pid" 2>/dev/null || return 0
        sleep 0.1
    done
    return 1
}

cleanup_iptables() {
    iptables -t nat -D OUTPUT -p tcp -j "$CHAIN" 2>/dev/null || true
    iptables -t nat -F "$CHAIN" 2>/dev/null || true
    iptables -t nat -X "$CHAIN" 2>/dev/null || true
    info "iptables $CHAIN chain removed."
}

# --- Main ---
check_root

pid=""
if [[ -f "$PID_FILE" ]]; then
    pid=$(<"$PID_FILE")
fi

if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    kill -TERM "$pid" 2>/dev/null || true
    if wait_for_exit "$pid"; then
        info "stopped pdanet-proxy.py (PID $pid)"
    else
        kill -KILL "$pid" 2>/dev/null || true
        info "stopped pdanet-proxy.py (PID $pid, forced)"
    fi
else
    found_pid=$(pgrep -f "/home/ayu/.local/bin/pdanet-proxy.py" 2>/dev/null | head -1 || true)
    if [[ -n "${found_pid:-}" ]]; then
        kill -TERM "$found_pid" 2>/dev/null || true
        wait_for_exit "$found_pid" || kill -KILL "$found_pid" 2>/dev/null || true
        info "stopped pdanet-proxy.py (PID $found_pid)"
    else
        info "no proxy running"
    fi
fi

cleanup_iptables

rm -f "$PID_FILE" 2>/dev/null || true
