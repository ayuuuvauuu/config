#!/usr/bin/env bash
set -euo pipefail

die() { echo "ERROR: $*" >&2; exit 1; }

gw=$(ip route | awk '/^default/{print $3; exit}')
[ -n "$gw" ] || { echo "ERROR: no default gateway — connect PDANet first" >&2; exit 1; }
echo "gateway=$gw"

export PDANET_PROXY_HOST="$gw"
exec python3 /home/ayu/.local/bin/pdanet-proxy.py
