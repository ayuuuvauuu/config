#!/usr/bin/env bash
set -euo pipefail

PID_FILE="${PDANET_PROXY_PID_FILE:-/tmp/pdanet-proxy.pid}"
CHAIN="PDANET"

info() { echo "$*"; }

check_proxy() {
    local pid
    if [[ -f "$PID_FILE" ]]; then
        pid=$(<"$PID_FILE")
    else
        pid=$(pgrep -f "/home/ayu/.local/bin/pdanet-proxy.py" 2>/dev/null | head -1 || true)
    fi
    if [[ -n "$pid" ]]; then
        if [[ ! -f "$PID_FILE" ]] || kill -0 "$pid" 2>/dev/null; then
            local up
            up=$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ')
            info "proxy: running (PID $pid, up $up)"
            return 0
        fi
    fi
    info "proxy: not running"
    return 1
}

check_iptables() {
    if iptables -t nat -L "$CHAIN" &>/dev/null; then
        local n
        n=$(iptables -t nat -L "$CHAIN" -n 2>/dev/null | wc -l)
        info "iptables $CHAIN: active ($((n - 3)) rules)"
        return 0
    fi
    info "iptables $CHAIN: inactive"
    return 1
}

check_connect() {
    local ext_ip
    ext_ip=$(
        env -u http_proxy -u https_proxy -u HTTP_PROXY -u HTTPS_PROXY \
            curl -s --noproxy '*' -m 10 https://1.1.1.1/cdn-cgi/trace 2>/dev/null | \
            grep -oE 'ip=[0-9.]+' | cut -d= -f2 | head -1 || true
    )
    if [[ -n "$ext_ip" ]]; then
        info "connect: OK (IP $ext_ip)"
        return 0
    fi
    info "connect: FAILED"
    return 1
}

# --- Main ---
info "=== PDANet proxy ==="
info ""

s=0
check_proxy || s=1
check_iptables || s=1
check_connect || s=1

info ""
if [[ $s -eq 0 ]]; then
    info "All checks OK."
else
    info "Run: sudo pdanet-proxy-start"
fi
