#!/usr/bin/env python3
import os, sys, signal, json, socket, subprocess, time

PID_FILE = "/tmp/codex-zen.pid"
RELAY_HOST = "127.0.0.1"
RELAY_PORT = 4444
PROXY_HOST = "127.0.0.1"
PROXY_PORT = 4445
PROXY_BIN = os.path.expanduser("~/.local/bin/responses-proxy")
PROXY_CONFIG = os.path.expanduser("~/.responses-proxy/config.yaml")
API_KEY = "sk-cTP0bMD0J1adeYe6IApGmc0I31uOHBBwl9x2VsKRxxGWmIyxG41XflAqql8e4Esu"

def port_open(host, port, timeout=2):
    try:
        s = socket.create_connection((host, port), timeout=timeout)
        s.close()
        return True
    except (OSError, socket.error):
        return False

def stop_infra():
    if os.path.exists(PID_FILE):
        with open(PID_FILE) as f:
            pids = [int(p) for p in f.read().strip().split()]
        for pid in pids:
            try:
                os.kill(pid, signal.SIGTERM)
                print(f"Stopped PID {pid}")
            except ProcessLookupError:
                pass
        os.unlink(PID_FILE)
    else:
        print("No infra to stop")

def set_pdeathsig():
    import ctypes
    libc = ctypes.CDLL("libc.so.6")
    libc.prctl(1, signal.SIGTERM)

def run_relay():
    import http.server
    from http.client import HTTPConnection

    def _model_info(m):
        return {
            "slug": m["id"],
            "display_name": m["id"],
            "description": "",
            "default_reasoning_level": "low",
            "supported_reasoning_levels": [{"effort": "low", "description": ""}],
            "shell_type": "shell_command",
            "visibility": "list",
            "supported_in_api": True,
            "priority": 0,
            "additional_speed_tiers": [],
            "service_tiers": [],
            "default_service_tier": None,
            "upgrade": None,
            "base_instructions": "",
            "model_messages": {
                "instructions_template": "",
                "instructions_variables": None,
                "approvals": None,
                "auto_review": None,
            },
            "include_skills_usage_instructions": False,
            "supports_reasoning_summaries": False,
            "default_reasoning_summary": "none",
            "support_verbosity": False,
            "default_verbosity": "low",
            "apply_patch_tool_type": "freeform",
            "web_search_tool_type": "text_and_image",
            "truncation_policy": {"mode": "tokens", "limit": 10000},
            "supports_parallel_tool_calls": True,
            "supports_image_detail_original": False,
            "supports_search_tool": True,
            "use_responses_lite": True,
            "tool_mode": "code_mode_only",
            "multi_agent_version": "v1",
            "context_window": 32000,
            "max_context_window": 64000,
            "availability_nux": None,
            "effective_context_window_percent": 95,
            "input_modalities": ["text"],
            "auto_compact_token_limit": None,
            "comp_hash": "",
            "experimental_supported_tools": [],
            "auto_review_model_override": None,
        }

    class Handler(http.server.BaseHTTPRequestHandler):
        def _forward_get(self, path):
            conn = HTTPConnection(PROXY_HOST, PROXY_PORT, timeout=30)
            skip = {"host", "connection", "accept-encoding"}
            hdrs = {k: v for k, v in self.headers.items() if k.lower() not in skip}
            conn.request("GET", path, headers=hdrs)
            return conn.getresponse()

        def do_GET(self):
            resp = self._forward_get(self.path)
            body = resp.read()

            if self.path.startswith("/v1/models"):
                raw = json.loads(body)
                if "data" in raw and "models" not in raw:
                    models = [_model_info(m) for m in raw["data"]]
                    body = json.dumps({"models": models}).encode()

            self.send_response(resp.status)
            for k, v in resp.getheaders():
                if k.lower() not in ("transfer-encoding", "content-length"):
                    self.send_header(k, v)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            self.wfile.flush()

        def do_POST(self):
            length = int(self.headers.get("Content-Length", 0))
            raw = self.rfile.read(length)
            body = json.loads(raw)
            for item in body.get("input", []):
                if item.get("role") == "developer":
                    item["role"] = "system"
            data = json.dumps(body).encode()

            conn = HTTPConnection(PROXY_HOST, PROXY_PORT, timeout=120)
            skip = {"host", "content-length", "transfer-encoding", "connection", "accept-encoding"}
            out_hdrs = {k: v for k, v in self.headers.items() if k.lower() not in skip}
            conn.request("POST", self.path, body=data, headers=out_hdrs)
            resp = conn.getresponse()
            is_stream = body.get("stream", False) or resp.getheader("content-type", "") == "text/event-stream"

            self.send_response(resp.status)
            for k, v in resp.getheaders():
                if k.lower() not in ("transfer-encoding", "content-length"):
                    self.send_header(k, v)
            if is_stream:
                self.send_header("Cache-Control", "no-cache")
                self.send_header("Connection", "keep-alive")
            self.end_headers()

            try:
                while True:
                    chunk = resp.read(65536)
                    if not chunk:
                        break
                    self.wfile.write(chunk)
                    if is_stream:
                        self.wfile.flush()
            except (BrokenPipeError, ConnectionResetError):
                pass
            finally:
                if is_stream:
                    self.wfile.flush()

        def log_message(self, fmt, *args):
            pass

    server = http.server.HTTPServer((RELAY_HOST, RELAY_PORT), Handler)
    server.allow_reuse_address = True
    signal.signal(signal.SIGTERM, lambda *a: sys.exit(0))
    server.serve_forever()

def start_infra():
    os.environ["OPENCODE_ZEN_API_KEY"] = API_KEY

    proxy = subprocess.Popen(
        [PROXY_BIN, "-c", PROXY_CONFIG],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        start_new_session=True,
    )

    for _ in range(10):
        if port_open(PROXY_HOST, PROXY_PORT, timeout=1):
            break
        time.sleep(1)
    else:
        print("Error: responses-proxy failed to start", file=sys.stderr)
        proxy.kill()
        sys.exit(1)

    relay = subprocess.Popen(
        [sys.executable, __file__, "--relay"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        start_new_session=True,
    )

    for _ in range(5):
        if port_open(RELAY_HOST, RELAY_PORT, timeout=1):
            break
        time.sleep(1)
    else:
        print("Error: relay failed to start", file=sys.stderr)
        proxy.kill()
        relay.kill()
        sys.exit(1)

    with open(PID_FILE, "w") as f:
        f.write(f"{relay.pid}\n{proxy.pid}")
    print(f"Infra ready (relay :{RELAY_PORT}, proxy :{PROXY_PORT})", file=sys.stderr)

def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--stop":
        stop_infra()
        return

    if len(sys.argv) > 1 and sys.argv[1] == "--relay":
        run_relay()
        return

    if not port_open(RELAY_HOST, RELAY_PORT, timeout=1):
        start_infra()
    else:
        print("Infra already running", file=sys.stderr)

    args = ["codex"] + sys.argv[1:] if sys.argv[1:] else ["codex"]
    codex = subprocess.Popen(args)

    try:
        codex.wait()
    except KeyboardInterrupt:
        codex.send_signal(signal.SIGINT)
        codex.wait()

    sys.exit(codex.returncode)

if __name__ == "__main__":
    main()
